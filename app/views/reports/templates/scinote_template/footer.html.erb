<style>
  .print-footer {
    line-height: 50px;
    font-size: 13px;
    padding-right: 30px;
    text-align: right;
    width: 100%;
  }
</style>

<div class="print-footer">
  <p>
    <% Time.zone = user.settings.dig(:time_zone) || 'UTC' %>
    <% if report&.settings&.dig('report_info_metadata') %>
      <%= t('projects.reports.new.generate_PDF.generated_on_with_info', subdomain: parse_subdomain,
                                                                        timestamp: I18n.l(Time.zone.now, format: :full),
                                                                        reportid: report.code,
                                                                        version: Scinote::Application::VERSION) %>
    <% else %>
      <%= t('projects.reports.new.generate_PDF.generated_on', timestamp: I18n.l(Time.zone.now, format: :full)) %>
    <% end %>
  </p>
</div>
